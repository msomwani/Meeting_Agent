{
  "manifest_version": 3,
  "name": "MeetMind",
  "version": "1.0.0",
  "description": "Privacy-first meeting intelligence — captures tab audio and produces AI meeting reports locally.",

  "permissions": [
    "tabCapture",
    "offscreen",
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "ws://localhost:8000/*",
    "http://localhost:8000/*"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
# MeetMind — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# ── Required ────────────────────────────────────────────────────────────────

# Groq API key — get from console.groq.com (free, no credit card)
GROQ_API_KEY=your_groq_api_key_here

# HuggingFace token — get from huggingface.co/settings/tokens (free)
# Also accept pyannote model terms at:
# huggingface.co/pyannote/speaker-diarization-3.1
HUGGINGFACE_TOKEN=your_huggingface_token_here

# ── Auto-set by start.py ────────────────────────────────────────────────────

# Whisper model size: base | small | medium | large-v2
# start.py sets this automatically based on your hardware
# You can also change it from the dashboard settings panel
WHISPER_MODEL=small

# Device: cpu | cuda | mps
# start.py sets this automatically
WHISPER_DEVICE=cpu

# ── Optional — Langfuse observability ───────────────────────────────────────

# Get from cloud.langfuse.com (free tier)
# Traces all LLM calls, latency, token usage across all 5 agent nodes
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── Optional — Database ─────────────────────────────────────────────────────

# Path to SQLite database file (default: meetmind.db in project root)
DATABASE_PATH=meetmind.db

# ── Version 2 flag ───────────────────────────────────────────────────────────

# Controls the audio processing layer (Version 1 = local, Version 2 = cloud)
# true  → WhisperX (local) + pyannote (local)   — Version 1 default
# false → Groq Whisper API + AssemblyAI          — Version 2
USE_LOCAL_MODELS=true

# ── Version 2 cloud keys (required when USE_LOCAL_MODELS=false) ──────────────

# AssemblyAI API key — get from app.assemblyai.com (free tier available)
# Used for cloud speaker diarization
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Note: GROQ_API_KEY above is reused for both LLM agents and Whisper transcription
